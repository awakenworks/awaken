{
  "name": "awaken-admin-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run tokens:build",
    "prebuild": "npm run tokens:build",
    "pretest": "npm run tokens:build",
    "dev": "vite --host 127.0.0.1 --port 3002",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview --host 127.0.0.1 --port 3002",
    "test": "vitest run",
    "tokens:build": "node design-tokens/config/style-dictionary.config.mjs",
    "tokens:dev": "node design-tokens/config/style-dictionary.config.mjs --watch",
    "tokens:validate": "node design-tokens/scripts/validate.mjs",
    "ci": "npm run tokens:validate && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.81",
    "@rjsf/core": "^6.4.2",
    "@rjsf/utils": "^6.4.2",
    "@rjsf/validator-ajv8": "^6.4.2",
    "@tanstack/react-query": "^5.100.9",
    "ai": "^6.0.79",
    "i18next": "^26.0.8",
    "react": "19",
    "react-dom": "19",
    "react-i18next": "^17.0.6",
    "react-router": "^7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5",
    "prettier": "^3.8.3",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^3.4",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2",
    "vite": "^6",
    "vitest": "^4.0.18"
  }
}
