---
/**
 * Awaken landing page — recreated from the Claude Design handoff at
 * https://api.anthropic.com/v1/design/h/WTbcjdRDrToEgOevKrbvrQ
 *
 * Single component containing all sections so the EN and zh-CN MDX
 * entry-points stay one-liners. Strings are localised inline via the
 * `t()` helper; markup is identical across locales.
 */

import { Code } from "astro:components";
import awakenMark from "../../assets/awaken-mark.svg";
import awakenTheme from "../../styles/shiki/awaken.json";
import heroSnippet from "../../snippets/hero-quickstart.rs?raw";

/* Note: SiteFooter is rendered globally by src/components/CustomFooter.astro
 * (registered as starlight.components.Footer). Starlight 0.39 invokes the
 * Footer override on splash pages too, so we DO NOT render <SiteFooter />
 * here — that would duplicate it on the landing page. */

interface Props {
  locale: "en" | "zh-CN";
}

const { locale } = Astro.props;
const t = <T,>(en: T, zh: T): T => (locale === "zh-CN" ? zh : en);

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const docsBase = locale === "zh-CN" ? `${baseUrl}/zh-cn` : baseUrl;
const demoGif = `${baseUrl}/assets/${locale === "zh-CN" ? "awaken-demo-zh.gif" : "awaken-demo.gif"}`;
const awakenMarkSrc = typeof awakenMark === "string" ? awakenMark : awakenMark.src;
---

<div class="landing-page">
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-left">
        <span class="hero-eyebrow">
          <img class="mark" src={awakenMarkSrc} alt="" loading="eager" />
          <span>{t("build in Rust · tune live · serve protocols", "Rust 构建 · 在线调优 · 多协议服务")}</span>
        </span>
        <h1 class="hero-title">
          {locale === "zh-CN" ? (
            <Fragment>
              <span class="accent">写一次能力，</span>持续调优 Agent
            </Fragment>
          ) : (
            <Fragment>
              Build agents in Rust.<span class="accent"> Tune them live.</span>
            </Fragment>
          )}
        </h1>
        <p class="hero-sub">
          {t(
            "Keep tools, state, providers, and plugins in production Rust code. Tune prompts, models, permissions, skills, and eval loops through managed config and the Admin Console — without rebuilding the runtime.",
            "Tools、state、providers、plugins 留在生产级 Rust 代码里；prompts、models、permissions、skills 与 eval loop 通过托管配置和管理控制台在线调优，无需重建 runtime。",
          )}
        </p>
        <div class="hero-icon-badges" aria-label={t("Awaken strengths", "Awaken 重点能力")}>
          <span class="hero-icon-badge">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v18"></path>
              <path d="m8 7 4-4 4 4"></path>
              <path d="m8 17 4 4 4-4"></path>
              <path d="M4 12h16"></path>
            </svg>
            <span>{t("Rust core", "Rust 内核")}</span>
          </span>
          <span class="hero-icon-badge">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 7h10"></path><path d="M18 7h2"></path>
              <path d="M4 17h2"></path><path d="M10 17h10"></path>
              <circle cx="16" cy="7" r="2"></circle><circle cx="8" cy="17" r="2"></circle>
            </svg>
            <span>{t("Live tuning", "在线调优")}</span>
          </span>
          <span class="hero-icon-badge">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 5v14"></path>
              <path d="M5 12h14"></path>
              <path d="M7 7h.01M17 7h.01M7 17h.01M17 17h.01"></path>
            </svg>
            <span>{t("Protocol ready", "协议就绪")}</span>
          </span>
        </div>
        <div class="hero-tune-card">
          <div>
            <span class="hero-tune-kicker">{t("Tune-first control plane", "调优优先的控制面")}</span>
            <strong>{t("Edits apply on the next run; running work keeps its resolved snapshot.", "修改在下一次 run 生效；运行中的任务保留已解析 snapshot。")}</strong>
          </div>
          <a href={`${docsBase}/operate/`}>{t("See tuning workflow →", "查看调优流程 →")}</a>
        </div>
        <div class="hero-actions">
          <a class="btn btn-primary" href={`${docsBase}/get-started/`}>
            <span>{t("Get started", "快速开始")}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </a>
          <a class="btn btn-secondary" href={`${docsBase}/how-to/use-admin-console/`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="14" rx="2"></rect>
              <path d="M8 20h8M12 18v2M7 8h4M7 12h10"></path>
            </svg>
            <span>{t("Open Admin Console guide", "打开控制台指南")}</span>
          </a>
        </div>
        <div class="hero-meta">
          <span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"></path></svg>
            <span>{t("Rust 1.93 MSRV", "MSRV: Rust 1.93")}</span>
          </span>
          <span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"></path></svg>
            <span><code>unsafe_code = "forbid"</code></span>
          </span>
          <span>
            <a href="https://github.com/AwakenWorks/awaken">GitHub</a>
          </span>
          <span>
            {t("Install", "安装")}:
            <button
              type="button"
              class="copy-code"
              data-copy="cargo add awaken --git https://github.com/AwakenWorks/awaken"
              aria-label={t("Copy install command", "复制安装命令")}
            >
              cargo add awaken --git …
              <svg class="copy-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg class="copy-icon-ok" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
            </button>
          </span>
        </div>
      </div>
      <div class="hero-right">
        <div class="terminal" role="img" aria-label={t("Rust quickstart", "Rust 快速开始")}>
          <div class="terminal-bar">
            <div class="dots"><span></span><span></span><span></span></div>
            <span class="file">src/main.rs</span>
            <span class="tag">main branch API</span>
          </div>
          <Code code={heroSnippet} lang="rust" theme={awakenTheme as never} />
          <div class="phase-ribbon" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ADMIN CONSOLE PREVIEW (moved up — concrete proof first) ============ -->
  <section class="band canvas">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Admin Console", "管理控制台")}</span>
          <h2>{t("Tune live, then operate with evidence", "在线调优，并用证据运营")}</h2>
          <p set:html={t(
            "The Admin Console is the tuning surface over the server APIs: edit agents, prompts, models, permissions, skills, MCP, traces, datasets, and eval runs from one control plane.",
            "管理控制台是 server API 之上的调优界面：agents、prompts、models、permissions、skills、MCP、traces、datasets 与 eval runs 都在同一个控制面管理。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/how-to/use-admin-console/`}>{t("Open console guide →", "打开控制台指南 →")}</a>
        </div>
      </div>
      <figure class="console-demo">
        <img
          src={demoGif}
          width="900"
          loading="lazy"
          alt={t(
            "Awaken admin console walkthrough — connect Gemini on Vertex, build an agent by hand, run a live eval",
            "Awaken 管理控制台走查 —— 接入 Vertex 上的 Gemini、手动构建 agent、运行实时评测",
          )}
        />
        <figcaption>
          {t("Recorded against a live Gemini backend.", "录制于真实 Gemini 后端。")}
          {" "}
          <a href={`${docsBase}/how-to/use-admin-console/`}>{t("Try it →", "动手试试 →")}</a>
        </figcaption>
      </figure>
      <div class="console-callouts tune-callouts">
        <div class="callout tune-primary">
          <span class="callout-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 7h10"></path><path d="M18 7h2"></path>
              <path d="M4 17h2"></path><path d="M10 17h10"></path>
              <circle cx="16" cy="7" r="2"></circle><circle cx="8" cy="17" r="2"></circle>
            </svg>
          </span>
          <div class="eb">{t("Live tuning", "在线调优")}</div>
          <h3>{t("Prompts, models, permissions, and skills change through config", "Prompts、models、permissions、skills 都通过配置变更")}</h3>
          <p set:html={t(
            "Edit through the Admin Console or <code>/v1/config/*</code>. The server validates the draft, publishes a registry snapshot, and the next run resolves against it.",
            "通过管理控制台或 <code>/v1/config/*</code> 编辑。server 校验草稿、发布 registry snapshot，下一次 run 使用新版解析。",
          )} />
        </div>
        <div class="callout">
          <span class="callout-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19V5"></path><path d="M4 19h16"></path>
              <path d="m8 15 3-3 3 2 5-6"></path>
              <path d="M17 8h2v2"></path>
            </svg>
          </span>
          <div class="eb">{t("Eval loop", "评测闭环")}</div>
          <h3>{t("Capture traces, turn them into datasets, compare behavior", "采集 trace，生成 dataset，对比行为")}</h3>
          <p>{t(
            "Tune with evidence: replay fixtures, score outputs, inspect diffs, then publish the next agent spec.",
            "用证据调优：回放 fixtures、打分输出、检查 diff，再发布下一版 agent spec。",
          )}</p>
        </div>
        <div class="callout">
          <span class="callout-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3 20 6v5c0 5-3.4 8.5-8 10-4.6-1.5-8-5-8-10V6l8-3Z"></path>
              <path d="M9 12h6"></path><path d="M12 9v6"></path>
            </svg>
          </span>
          <div class="eb">{t("Auditability", "可审计")}</div>
          <h3>{t("Every saved change can be inspected and restored", "每次保存都可检查、可恢复")}</h3>
          <p>{t(
            "Config revisions and audit restore make prompt/model/policy tuning reviewable instead of hidden in deploy scripts.",
            "Config revision 与 audit restore 让 prompt/model/policy 调优可审查，而不是藏在部署脚本里。",
          )}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TWO LAYERS ============ -->
  <section class="band">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Mental model", "心智模型")}</span>
          <h2>{t("Runtime for code, server for operations", "runtime 写代码,server 做运营")}</h2>
          <p set:html={t(
            "<b>Runtime mode</b> keeps executable capability in Rust: tools, providers, state, plugins, and direct <code>RunActivation</code> execution. <b>Server mode</b> wraps it with durable runs, protocols, and managed config.",
            "<b>runtime 模式</b>把可执行能力留在 Rust：tools、providers、state、plugins 与直接 <code>RunActivation</code> 执行。<b>server 模式</b>在外层加入持久 run、协议与托管配置。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/operate/`}>{t("Tune workflow →", "调优流程 →")}</a>
        </div>
      </div>
      <div class="decisions-grid">
        <div class="callout">
          <div class="eb">{t("Code (Rust)", "代码层（Rust）")}</div>
          <h3>{t("Tools · State · Plugins", "Tools · State · Plugins")}</h3>
          <p set:html={t(
            "<b>Tools</b> as <code>Tool</code> / <code>TypedTool</code> impls with `schemars`-derived JSON Schema. <b>State</b> is typed: `StateKey` declares merge strategy + scope; commits are atomic per phase. <b>Plugins</b> hook the 9-phase loop by name.",
            "<b>Tools</b> 实现 <code>Tool</code> / <code>TypedTool</code>，用 `schemars` 自动生成 JSON Schema。<b>State</b> 是类型化的：`StateKey` 声明合并策略与作用域，每个 phase 末原子提交。<b>Plugins</b> 按名挂载到 9 阶段循环。",
          )} />
        </div>
        <div class="callout">
          <div class="eb">{t("Config (declarative)", "配置层（声明式）")}</div>
          <h3>{t("Providers · Models · Agents · Skills", "Providers · Models · Agents · Skills")}</h3>
          <p set:html={t(
            "Mutate through <code>/v1/config/*</code> (REST) or the admin console (UI) — both are server surfaces over the same registry snapshot. Existing runs keep their resolved spec; new runs pick up the edit.",
            "通过 <code>/v1/config/*</code>（REST）或控制台（UI）变更，二者都是 server 暴露在同一个 registry snapshot 上的控制面。进行中的 run 保留已解析 spec，新 run 拿到新版。",
          )} />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROTOCOL MATRIX ============ -->
  <section class="band canvas">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Server surface", "server 表面")}</span>
          <h2>{t("Five protocols without five agents", "五种协议,不是五套 Agent")}</h2>
          <p set:html={t(
            "The server translates each wire format into the same runtime event stream and run model. Switch clients without touching agent code.",
            "server 把每种 wire format 转成同一条 runtime event stream 和 run model。切换客户端无需改动 agent 代码。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/serve-and-integrate/`}>{t("Serve & integrate →", "服务与集成 →")}</a>
        </div>
      </div>
      <div class="proto-grid">
        <article class="proto-card">
          <div class="proto-icon">SDK</div>
          <h3>AI SDK v6</h3>
          <div class="proto-endpoint">POST /v1/ai-sdk/chat</div>
          <p class="proto-desc" set:html={t(
            "Stream chunks to Vercel AI SDK's <code>useChat()</code> — text, tool calls, and finish events.",
            "把流式分块发到 Vercel AI SDK 的 <code>useChat()</code> —— 文本、工具调用、完成事件。",
          )} />
          <div class="proto-frontend">React · Next.js</div>
        </article>
        <article class="proto-card">
          <div class="proto-icon">AG</div>
          <h3>AG-UI</h3>
          <div class="proto-endpoint">POST /v1/ag-ui/run</div>
          <p class="proto-desc" set:html={t(
            "CopilotKit's <code>&lt;CopilotKit&gt;</code> drop-in for chat, generative UI, and HITL.",
            "CopilotKit 的 <code>&lt;CopilotKit&gt;</code> 直接接入,支持聊天、Generative UI 与 HITL。",
          )} />
          <div class="proto-frontend">CopilotKit</div>
        </article>
        <article class="proto-card">
          <div class="proto-icon">A2A</div>
          <h3>A2A</h3>
          <div class="proto-endpoint">POST /v1/a2a/message:send</div>
          <p class="proto-desc">{t(
            "Agent-to-agent messaging — let other agents call yours as a remote sub-agent.",
            "智能体间通信 —— 让其他智能体把你的当成远程子智能体调用。",
          )}</p>
          <div class="proto-frontend">{t("Foreign agents", "外部智能体")}</div>
        </article>
        <article class="proto-card">
          <div class="proto-icon">MCP</div>
          <h3>MCP</h3>
          <div class="proto-endpoint">POST /v1/mcp</div>
          <p class="proto-desc">{t(
            "JSON-RPC 2.0 surface for MCP-compatible clients over the server route.",
            "面向 MCP 兼容客户端的 JSON-RPC 2.0 server route。",
          )}</p>
          <div class="proto-frontend">Claude · Cursor · Zed</div>
        </article>
        <article class="proto-card">
          <div class="proto-icon">ACP</div>
          <h3>ACP</h3>
          <div class="proto-endpoint">stdio serve_stdio</div>
          <p class="proto-desc">{t(
            "Agent Client Protocol stdio adapter from the server crate.",
            "server crate 提供的 Agent Client Protocol stdio 适配器。",
          )}</p>
          <div class="proto-frontend">{t("ACP hosts", "ACP 宿主")}</div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ 9-PHASE LOOP (moved down — explains how the above works) ============ -->
  <section class="band">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Inside the runtime", "运行时内部")}</span>
          <h2>{t("A 9-phase loop, not a DAG", "9 阶段循环,而非 DAG")}</h2>
          <p>{t(
            "Every run flows through nine typed phases. Plugins hook in by name. State commits atomically at the end of each round.",
            "每次运行都流经 9 个类型化阶段。插件按名称挂载,状态在每轮结束时原子提交。",
          )}</p>
        </div>
        <div class="right">
          <a href={`${docsBase}/explanation/run-lifecycle-and-phases/`}>{t("Phase reference →", "阶段参考 →")}</a>
        </div>
      </div>
      <div class="phase-loop">
        <div class="phase-list">
          <div class="phase-pill" style="--c: var(--aw-phase-resolve)"><span class="num">1</span> <span class="lbl">resolve</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-prepare)"><span class="num">2</span> <span class="lbl">prepare</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-prompt)"><span class="num">3</span> <span class="lbl">prompt</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-stream)"><span class="num">4</span> <span class="lbl">stream</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-gate)"><span class="num">5</span> <span class="lbl">gate</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-tool)"><span class="num">6</span> <span class="lbl">tool</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-commit)"><span class="num">7</span> <span class="lbl">commit</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-events)"><span class="num">8</span> <span class="lbl">events</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-finalize)"><span class="num">9</span> <span class="lbl">finalize</span></div>
        </div>
        <div class="phase-explain">
          <h3>{t("Snapshot in, batch out.", "快照进,批次出。")}</h3>
          <p set:html={t(
            "Each phase reads an immutable state snapshot and returns a typed mutation batch. <code>commit</code> applies the batch atomically — no partial writes, no surprise interleaving when tools run in parallel. The pure <code>gate</code> phase decides which tool calls to authorise before <code>tool</code> executes; permission, reminder, and HITL plugins all hook here.",
            "每个阶段读取不可变状态快照，返回类型化变更批次。<code>commit</code> 阶段原子应用，工具并行执行也不会出现部分写入或交叉污染。纯函数的 <code>gate</code> 阶段在 <code>tool</code> 执行前裁决工具调用 —— 权限、提醒与 HITL 插件都挂载在此。",
          )} />
          <div class="phase-callout">
            <b>{t("Stream recovery built in.", "内建流式恢复。")}</b>
            <span set:html={t(
              " Idle stalls and mid-stream errors are caught with four explicit plans: continue text, replay completed tools, restart with a cancelled-tool hint, or whole restart. <code>Retry-After</code> is honoured; checkpoints persist across process restarts.",
              " 空闲超时与流中断由四个显式恢复计划处理：续写文本、回放已完成工具、提示工具取消重启、整轮重启。<code>Retry-After</code> 被遵守；检查点跨进程重启持久化。",
            )} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BUILT-IN PLUGINS ============ -->
  <section class="band canvas">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Plugins", "插件")}</span>
          <h2>{t("Batteries that opt in", "按需开启的电池组")}</h2>
          <p set:html={t(
            "Built-in and companion extension crates expose the same <code>trait Plugin</code> + hook model you use for custom capability. Opt in only to the surfaces your agent needs.",
            "内置与配套扩展 crate 使用同一套 <code>trait Plugin</code> + hook 模型，也适用于你的自定义能力。只接入当前 agent 需要的表面。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/explanation/tool-and-plugin-boundary/`}>{t("Tool/plugin boundary →", "Tool/Plugin 边界 →")}</a>
        </div>
      </div>
      <div class="plugins-grid">
        <div class="plugin-card">
          <div class="pname"><h4>Permission</h4><span class="flag">permission</span></div>
          <p>{t(
            "Allow / Deny / Ask rules on tool name + args. Ask suspends the run for HITL via the mailbox.",
            "工具名 + 参数上的 Allow / Deny / Ask 规则。Ask 通过 mailbox 挂起等待 HITL。",
          )}</p>
        </div>
        <div class="plugin-card">
          <div class="pname"><h4>Reminder</h4><span class="flag">reminder</span></div>
          <p>{t(
            "Inject system or conversation-level messages when a tool call matches a pattern.",
