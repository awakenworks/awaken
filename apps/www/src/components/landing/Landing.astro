---
/**
 * Awaken landing page — recreated from the Claude Design handoff at
 * https://api.anthropic.com/v1/design/h/WTbcjdRDrToEgOevKrbvrQ
 *
 * Single component containing all sections so the EN and zh-CN MDX
 * entry-points stay one-liners. Strings are localised inline via the
 * `t()` helper; markup is identical across locales.
 */

import { Code } from "astro:components";
import awakenTheme from "../../styles/shiki/awaken.json";
import heroSnippet from "../../snippets/hero-quickstart.rs?raw";

/* Note: SiteFooter is rendered globally by src/components/CustomFooter.astro
 * (registered as starlight.components.Footer). Starlight 0.39 invokes the
 * Footer override on splash pages too, so we DO NOT render <SiteFooter />
 * here — that would duplicate it on the landing page. */

interface Props {
  locale: "en" | "zh-CN";
}

const { locale } = Astro.props;
const t = <T,>(en: T, zh: T): T => (locale === "zh-CN" ? zh : en);

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const docsBase = locale === "zh-CN" ? `${baseUrl}/zh-cn` : baseUrl;
---

<div class="landing-page">
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-left">
        <span class="hero-eyebrow">
          <span class="dot"></span>
          <span>{t("v0.5 · type-safe state · 9-phase loop", "v0.5 · 类型化状态 · 9 阶段循环")}</span>
        </span>
        <h1 class="hero-title">
          {locale === "zh-CN" ? (
            <Fragment>
              <span class="accent">面向 Rust 的</span>生产级 AI Agent 运行时
            </Fragment>
          ) : (
            <Fragment>
              Production AI agent runtime<span class="accent"> for Rust.</span>
            </Fragment>
          )}
        </h1>
        <p class="hero-sub">
          {t(
            "One backend serves AI SDK, AG-UI, A2A, and MCP. Streams recover from mid-flight failures. State is typed, mutations are atomic, and the whole run is replayable from a snapshot.",
            "单后端同时服务 AI SDK、AG-UI、A2A 与 MCP。流式中断可恢复,状态类型化,变更原子提交,整轮可基于快照重放。",
          )}
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={`${docsBase}/get-started/`}>
            <span>{t("Get started", "快速开始")}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </a>
          <a class="btn btn-secondary" href="https://github.com/AwakenWorks/awaken">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.1-.4-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"></path>
            </svg>
            <span>{t("Star on GitHub", "Star 项目")}</span>
          </a>
        </div>
        <div class="hero-meta">
          <span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"></path></svg>
            <span>{t("Rust 1.93 MSRV", "MSRV: Rust 1.93")}</span>
          </span>
          <span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"></path></svg>
            <span><code>unsafe_code = "forbid"</code></span>
          </span>
          <span>
            {t("Install", "安装")}:
            <button
              type="button"
              class="copy-code"
              data-copy="cargo add awaken"
              aria-label={t("Copy install command", "复制安装命令")}
            >
              cargo add awaken
              <svg class="copy-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg class="copy-icon-ok" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
            </button>
          </span>
        </div>
      </div>
      <div class="hero-right">
        <div class="terminal" role="img" aria-label={t("Rust quickstart", "Rust 快速开始")}>
          <div class="terminal-bar">
            <div class="dots"><span></span><span></span><span></span></div>
            <span class="file">src/main.rs</span>
            <span class="tag">awaken = "0.5"</span>
          </div>
          <Code code={heroSnippet} lang="rust" theme={awakenTheme as never} />
          <div class="phase-ribbon" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TWO LAYERS ============ -->
  <section class="band canvas">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Mental model", "心智模型")}</span>
          <h2>{t("Two layers, one runtime", "两层模型,一个运行时")}</h2>
          <p set:html={t(
            "<b>Code</b> compiles once. <b>Config</b> tunes at runtime. Edits to model, agent, or skill spec take effect on the <b>next</b> <code>/v1/runs</code> — no restart, no redeploy.",
            "<b>代码</b>编译一次。<b>配置</b>运行时调优。Model、Agent、Skill spec 的改动在<b>下一次</b> <code>/v1/runs</code> 生效 —— 无需重启、无需重新部署。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/how-to/configure-agent-behavior/`}>{t("Tuning guide →", "调优指南 →")}</a>
        </div>
      </div>
      <div class="decisions-grid">
        <div class="callout">
          <div class="eb">{t("Code (Rust)", "代码层（Rust）")}</div>
          <h3>{t("Tools · State · Plugins", "Tools · State · Plugins")}</h3>
          <p set:html={t(
            "<b>Tools</b> as <code>Tool</code> / <code>TypedTool</code> impls with `schemars`-derived JSON Schema. <b>State</b> is typed: `StateKey` declares merge strategy + scope; commits are atomic per phase. <b>Plugins</b> hook the 9-phase loop by name.",
            "<b>Tools</b> 实现 <code>Tool</code> / <code>TypedTool</code>，用 `schemars` 自动生成 JSON Schema。<b>State</b> 是类型化的：`StateKey` 声明合并策略与作用域，每个 phase 末原子提交。<b>Plugins</b> 按名挂载到 9 阶段循环。",
          )} />
        </div>
        <div class="callout">
          <div class="eb">{t("Config (declarative)", "配置层（声明式）")}</div>
          <h3>{t("Providers · Models · Agents · Skills", "Providers · Models · Agents · Skills")}</h3>
          <p set:html={t(
            "Mutate through <code>/v1/config/*</code> (REST) or the admin console (UI) — they're the same API. Runtime publishes a new registry snapshot per change; existing runs keep their resolved spec, new ones pick up the edit. Audit log keeps every version.",
            "通过 <code>/v1/config/*</code>（REST）或控制台（UI）变更，二者是同一套 API。每次写入都会发布新的 registry snapshot；进行中的 run 保留已解析 spec，下一次 run 拿到新版。Audit log 保留每个版本。",
          )} />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROTOCOL MATRIX ============ -->
  <section class="band">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("One runtime", "一个运行时")}</span>
          <h2>{t("Four protocols, one backend", "四种协议,一套后端")}</h2>
          <p set:html={t(
            "Same <code>/v1/runs</code> handles every frontend. Switch protocols without touching agent code.",
            "同一个 <code>/v1/runs</code> 服务所有前端。切换协议无需改动智能体代码。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/serve-and-integrate/`}>{t("Wire-format reference →", "线协议参考 →")}</a>
        </div>
      </div>
      <div class="proto-grid">
        <article class="proto-card">
          <div class="proto-icon">SDK</div>
          <h3>AI SDK v6</h3>
          <div class="proto-endpoint">POST /v1/ai-sdk/chat</div>
          <p class="proto-desc" set:html={t(
            "Stream chunks to Vercel AI SDK's <code>useChat()</code> — text, tool calls, and finish events.",
            "把流式分块发到 Vercel AI SDK 的 <code>useChat()</code> —— 文本、工具调用、完成事件。",
          )} />
          <div class="proto-frontend">React · Next.js</div>
        </article>
        <article class="proto-card">
          <div class="proto-icon">AG</div>
          <h3>AG-UI</h3>
          <div class="proto-endpoint">POST /v1/ag-ui/run</div>
          <p class="proto-desc" set:html={t(
            "CopilotKit's <code>&lt;CopilotKit&gt;</code> drop-in for chat, generative UI, and HITL.",
            "CopilotKit 的 <code>&lt;CopilotKit&gt;</code> 直接接入,支持聊天、Generative UI 与 HITL。",
          )} />
          <div class="proto-frontend">CopilotKit</div>
        </article>
        <article class="proto-card">
          <div class="proto-icon">A2A</div>
          <h3>A2A</h3>
          <div class="proto-endpoint">POST /v1/a2a/message:send</div>
          <p class="proto-desc">{t(
            "Agent-to-agent messaging — let other agents call yours as a remote sub-agent.",
            "智能体间通信 —— 让其他智能体把你的当成远程子智能体调用。",
          )}</p>
          <div class="proto-frontend">{t("Foreign agents", "外部智能体")}</div>
        </article>
        <article class="proto-card">
          <div class="proto-icon">MCP</div>
          <h3>MCP</h3>
          <div class="proto-endpoint">POST /v1/mcp</div>
          <p class="proto-desc">{t(
            "JSON-RPC 2.0 surface — host any MCP-compatible client with stdio or HTTP transport.",
            "JSON-RPC 2.0 服务面 —— 通过 stdio 或 HTTP 传输承接任意 MCP 兼容客户端。",
          )}</p>
          <div class="proto-frontend">Claude · Cursor · Zed</div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ ADMIN CONSOLE PREVIEW (moved up — concrete proof first) ============ -->
  <section class="band canvas">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Admin Console", "管理控制台")}</span>
          <h2>{t("Operate it like a product, not a script", "把它当产品运营,而不是脚本")}</h2>
          <p set:html={t(
            "A React 19 SPA wired to the same <code>/v1/config/*</code> API. Manage agents, models, providers, skills, MCP — every change audited and snapshot-applied to the next run.",
            "一个 React 19 SPA，与 <code>/v1/config/*</code> 共享 API。管理 agents、models、providers、skills、MCP —— 每次变更都进入 audit log，下一次 run 立即生效。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/reference/admin-console/`}>{t("Full surface tour →", "完整界面导览 →")}</a>
        </div>
      </div>
      <div class="console-grid">
        <div class="console-shot" aria-label={t("Admin Console preview", "管理控制台预览")}>
          <div class="titlebar">
            <span class="d"></span><span class="d"></span><span class="d"></span>
            <span class="url">localhost:3002/agents</span>
          </div>
          <div class="console-body">
            <aside class="console-side">
              <div class="eb">{t("Agents", "智能体")}</div>
              <div class="item act">Agents <span class="dot"></span></div>
              <div class="eb" style="margin-top: 8px">{t("Resources", "资源")}</div>
              <div class="item">Models <span class="dot"></span></div>
              <div class="item">MCP Servers <span class="dot w"></span></div>
              <div class="item">Skills</div>
              <div class="item">Tools</div>
              <div class="eb" style="margin-top: 8px">{t("Observe", "观测")}</div>
              <div class="item">Dashboard</div>
              <div class="item">Audit Log</div>
              <div class="item">Eval Reports</div>
            </aside>
            <main class="console-main">
              <div class="crumbs">Agents</div>
              <div class="console-cards">
                <div class="cc">
                  <div class="lbl">{t("Agents", "智能体")}</div>
                  <div class="num">12</div>
                  <div class="delta">{t("registered", "已注册")}</div>
                </div>
                <div class="cc">
                  <div class="lbl">{t("Tools", "工具")}</div>
                  <div class="num">47</div>
                  <div class="delta">{t("built-in + plugin + MCP", "内置 + 插件 + MCP")}</div>
                </div>
              </div>
              <div class="console-table">
                <div class="row head">
                  <span>{t("Agent", "智能体")}</span><span>Model</span><span>{t("Inferences (24h)", "推理 (24h)")}</span>
                </div>
                <div class="row">
                  <span class="name">assistant</span>
                  <span class="pill live">gpt-4o-mini</span>
                  <span style="text-align: right; font-family: var(--aw-font-mono); font-size: 10.5px; color: var(--aw-text-soft)">2.1k</span>
                </div>
                <div class="row">
                  <span class="name">researcher</span>
                  <span class="pill agent">claude-3.7</span>
                  <span style="text-align: right; font-family: var(--aw-font-mono); font-size: 10.5px; color: var(--aw-text-soft)">847</span>
                </div>
                <div class="row">
                  <span class="name">summariser</span>
                  <span class="pill">deepseek-v3</span>
                  <span style="text-align: right; font-family: var(--aw-font-mono); font-size: 10.5px; color: var(--aw-text-soft)">112</span>
                </div>
              </div>
            </main>
          </div>
        </div>
        <div class="console-callouts">
          <div class="callout">
            <div class="eb">{t("Config = control plane", "配置即控制面")}</div>
            <h3>{t("Spec-first, runtime-applied", "声明先行,运行时即时生效")}</h3>
            <p set:html={t(
              "Models, providers, prompts, permissions, MCP — edit the spec and the next <code>/v1/runs</code> sees it. No restart.",
              "模型、Provider、提示词、权限、MCP —— 编辑 spec,下一次 <code>/v1/runs</code> 即生效。无需重启。",
            )} />
          </div>
          <div class="callout">
            <div class="eb">{t("Tested end-to-end", "端到端测试")}</div>
            <h3>{t("875 tests · 20 doctest examples", "875 个测试 · 20 个 doctest 示例")}</h3>
            <p set:html={t(
              "Workspace under <code>unsafe_code = \"forbid\"</code>. The coverage-map tracks 20 doc-cited API shapes; each example's <code>main()</code> runs in CI to catch silent rename / serde drift.",
              "整个 workspace <code>unsafe_code = \"forbid\"</code>。Coverage map 跟踪 20 个文档引用的 API 形状，每个示例的 <code>main()</code> 在 CI 真实执行，捕捉静默 rename 或 serde 漂移。",
            )} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 9-PHASE LOOP (moved down — explains how the above works) ============ -->
  <section class="band">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Inside the runtime", "运行时内部")}</span>
          <h2>{t("A 9-phase loop, not a DAG", "9 阶段循环,而非 DAG")}</h2>
          <p>{t(
            "Every run flows through nine typed phases. Plugins hook in by name. State commits atomically at the end of each round.",
            "每次运行都流经 9 个类型化阶段。插件按名称挂载,状态在每轮结束时原子提交。",
          )}</p>
        </div>
        <div class="right">
          <a href={`${docsBase}/explanation/run-lifecycle-and-phases/`}>{t("Phase reference →", "阶段参考 →")}</a>
        </div>
      </div>
      <div class="phase-loop">
        <div class="phase-list">
          <div class="phase-pill" style="--c: var(--aw-phase-resolve)"><span class="num">1</span> <span class="lbl">resolve</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-prepare)"><span class="num">2</span> <span class="lbl">prepare</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-prompt)"><span class="num">3</span> <span class="lbl">prompt</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-stream)"><span class="num">4</span> <span class="lbl">stream</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-gate)"><span class="num">5</span> <span class="lbl">gate</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-tool)"><span class="num">6</span> <span class="lbl">tool</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-commit)"><span class="num">7</span> <span class="lbl">commit</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-events)"><span class="num">8</span> <span class="lbl">events</span></div>
          <div class="phase-pill" style="--c: var(--aw-phase-finalize)"><span class="num">9</span> <span class="lbl">finalize</span></div>
        </div>
        <div class="phase-explain">
          <h3>{t("Snapshot in, batch out.", "快照进,批次出。")}</h3>
          <p set:html={t(
            "Each phase reads an immutable state snapshot and returns a typed mutation batch. <code>commit</code> applies the batch atomically — no partial writes, no surprise interleaving when tools run in parallel. The pure <code>gate</code> phase decides which tool calls to authorise before <code>tool</code> executes; permission, reminder, and HITL plugins all hook here.",
            "每个阶段读取不可变状态快照，返回类型化变更批次。<code>commit</code> 阶段原子应用，工具并行执行也不会出现部分写入或交叉污染。纯函数的 <code>gate</code> 阶段在 <code>tool</code> 执行前裁决工具调用 —— 权限、提醒与 HITL 插件都挂载在此。",
          )} />
          <div class="phase-callout">
            <b>{t("Stream recovery built in.", "内建流式恢复。")}</b>
            <span set:html={t(
              " Idle stalls and mid-stream errors are caught with four explicit plans: continue text, replay completed tools, restart with a cancelled-tool hint, or whole restart. <code>Retry-After</code> is honoured; checkpoints persist across process restarts.",
              " 空闲超时与流中断由四个显式恢复计划处理：续写文本、回放已完成工具、提示工具取消重启、整轮重启。<code>Retry-After</code> 被遵守；检查点跨进程重启持久化。",
            )} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BUILT-IN PLUGINS ============ -->
  <section class="band canvas">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">{t("Plugins", "插件")}</span>
          <h2>{t("Batteries that opt in", "按需开启的电池组")}</h2>
          <p set:html={t(
            "Seven typed extension surfaces, each gated by a cargo feature flag. Same <code>trait Plugin</code> + hooks the built-ins use — write your own with no special API.",
            "七个类型化扩展点，每个由 cargo feature flag 控制。<code>trait Plugin</code> + 各 hook 与内置插件完全一致 —— 自己写不需要任何特殊 API。",
          )} />
        </div>
        <div class="right">
          <a href={`${docsBase}/reference/overview/`}>{t("Plugin reference →", "插件参考 →")}</a>
        </div>
      </div>
      <div class="plugins-grid">
        <div class="plugin-card">
          <div class="pname"><h4>Permission</h4><span class="flag">permission</span></div>
          <p>{t(
            "Allow / Deny / Ask rules on tool name + args. Ask suspends the run for HITL via the mailbox.",
            "工具名 + 参数上的 Allow / Deny / Ask 规则。Ask 通过 mailbox 挂起等待 HITL。",
          )}</p>
        </div>
        <div class="plugin-card">
          <div class="pname"><h4>Reminder</h4><span class="flag">reminder</span></div>
          <p>{t(
            "Inject system or conversation-level messages when a tool call matches a pattern.",
            "工具调用匹配规则时，注入系统级或会话级消息。",
          )}</p>
        </div>
        <div class="plugin-card">
          <div class="pname"><h4>Observability</h4><span class="flag">observability</span></div>
          <p>{t(
            "OpenTelemetry traces + metrics in GenAI semantic conventions. OTLP / file / in-memory.",
            "符合 GenAI 语义约定的 OpenTelemetry traces + metrics。OTLP / 文件 / 内存。",
          )}</p>
        </div>
        <div class="plugin-card">
          <div class="pname"><h4>MCP</h4><span class="flag">mcp</span></div>
          <p>{t(
            "Connect to any MCP server — its tools register as native Awaken tools.",
            "连接任意 MCP 服务，其工具注册为原生 Awaken 工具。",
          )}</p>
        </div>
        <div class="plugin-card">
          <div class="pname"><h4>Skills</h4><span class="flag">skills</span></div>
          <p>{t(
            "Skill packages discovered and injected as a catalog — the LLM activates on demand.",
            "技能包自动发现并注入为目录 —— LLM 按需激活。",
          )}</p>
        </div>
        <div class="plugin-card">
          <div class="pname"><h4>Generative UI</h4><span class="flag">generative-ui</span></div>
          <p>{t(
            "Stream declarative UI via A2UI, JSON Render, and OpenUI Lang.",
