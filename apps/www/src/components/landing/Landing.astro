<script>
  /* Click-to-copy on the hero install chip. Single inline handler so the
   * pattern is easy to lift into a shared <CodeWithCopy> later. */
  for (const btn of document.querySelectorAll<HTMLButtonElement>("button.copy-code")) {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") ?? btn.textContent ?? "";
      try {
        await navigator.clipboard.writeText(text.trim());
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 1500);
      } catch {
        /* clipboard API blocked — silently no-op */
      }
    });
  }
</script>
