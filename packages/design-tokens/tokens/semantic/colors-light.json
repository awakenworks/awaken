{
  "aw": {
    "bg":          { "$value": "{color.slate.app}",     "$type": "color", "$description": "Page background" },
    "bg-canvas":   { "$value": "{color.slate.canvas}",  "$type": "color", "$description": "Canvas behind cards" },
    "bg-elevated": { "$value": "{color.slate.surface}", "$type": "color", "$description": "Card surfaces" },
    "bg-soft":     { "$value": "{color.slate.subtle}",  "$type": "color", "$description": "Tinted surface, zebra rows" },
    "bg-muted":    { "$value": "{color.slate.muted}",   "$type": "color", "$description": "Code, kbd" },
    "bg-hover":    { "$value": "{color.slate.subtle}",  "$type": "color" },
    "bg-pressed":  { "$value": "{color.slate.muted}",   "$type": "color" },

    "text":        { "$value": "{color.slate.fg}",        "$type": "color" },
    "text-strong": { "$value": "{color.slate.fg-strong}", "$type": "color" },
    "text-soft":   { "$value": "{color.slate.fg-muted}",  "$type": "color" },
    "text-faint":  { "$value": "{color.slate.fg-faint}",  "$type": "color" },

    "border":        { "$value": "{color.slate.line}",        "$type": "color" },
    "border-strong": { "$value": "{color.slate.line-strong}", "$type": "color" },

    "accent":        { "$value": "{color.indigo.accent}", "$type": "color" },
    "accent-soft":   { "$value": "{color.indigo.soft}",   "$type": "color" },
    "accent-text":   { "$value": "{color.indigo.fg}",     "$type": "color" },

    "link":             { "$value": "{color.blue.link}",       "$type": "color" },
    "link-hover":       { "$value": "{color.blue.link-hover}", "$type": "color" },
    "focus":            { "$value": "{color.blue.focus}",      "$type": "color" },
    "focus-soft":       { "$value": "{color.blue.focus-soft}", "$type": "color" },

    "success":    { "$value": "{color.tone.success}", "$type": "color" },
    "warning":    { "$value": "{color.tone.warn}",    "$type": "color" },
    "danger":     { "$value": "{color.tone.error}",   "$type": "color" },

    "tone": {
      "info":    { "$value": "{color.tone.info}",    "$type": "color" },
      "warn":    { "$value": "{color.tone.warn}",    "$type": "color" },
      "error":   { "$value": "{color.tone.error}",   "$type": "color" },
      "success": { "$value": "{color.tone.success}", "$type": "color" }
    },

    "state": {
      "backlog":  { "$value": "{color.state.backlog}",  "$type": "color" },
      "progress": { "$value": "{color.state.progress}", "$type": "color" },
      "review":   { "$value": "{color.state.review}",   "$type": "color" },
      "done":     { "$value": "{color.state.done}",     "$type": "color" },
      "blocked":  { "$value": "{color.state.blocked}",  "$type": "color" },
      "paused":   { "$value": "{color.state.paused}",   "$type": "color" }
    },

    "agent":        { "$value": "{color.violet.agent}",  "$type": "color" },
    "agent-tint":   { "$value": "{color.violet.tint}",   "$type": "color", "$description": "Row wash for AI-touched rows" },
    "agent-stripe": { "$value": "{color.violet.stripe}", "$type": "color", "$description": "Active agent left band" },
    "agent-fg":     { "$value": "{color.violet.fg}",     "$type": "color", "$description": "Text inside agent-tint" },

    "code-bg":      { "$value": "oklch(20.0% 0.018 250)", "$type": "color", "$description": "Code/pre block — always dark (terminal aesthetic, theme-invariant)" },
    "code-fg":      { "$value": "oklch(94.0% 0.005 80)",  "$type": "color", "$description": "Code/pre text — always light (paired with code-bg)" },
    "overlay":      { "$value": "oklch(15.0% 0 0 / 0.5)", "$type": "color", "$description": "Modal/dialog backdrop scrim" }
  }
}
